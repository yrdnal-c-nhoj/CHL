{
  "name": "borrowed-time",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "cleanup:modules": "node scripts/module-cleanup.mjs",
    "cleanup:test": "node scripts/test-cleanup.mjs",
    "cleanup:advanced": "node scripts/advanced-cleanup.mjs",
    "standardize:fonts": "node scripts/standardize-fonts.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "audit:fonts": "node scripts/audit-fonts.mjs",
    "audit:images": "node scripts/audit-images.mjs",
    "test": "vitest",
    "perf:analyze": "vite build --mode analyze",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^9.0.0",
    "@react-three/fiber": "^8.0.0",
    "axios": "^1.6.0",
    "gsap": "^3.12.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-helmet-async": "^2.0.0",
    "react-router-dom": "^6.22.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^7.0.0",
    "vite-plugin-compression": "^0.5.0",
    "vitest": "^1.4.0"
  }
}