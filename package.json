{
  "name": "BorrowedTime",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:with-types": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "clock:new": "mkdir -p src/pages/$(date +%Y)/$(date +%y-%m)/$(date +%y-%m-%d) && cp src/templates/MasterTemplate.tsx src/pages/$(date +%Y)/$(date +%y-%m)/$(date +%y-%m-%d)/Clock.tsx && touch src/pages/$(date +%Y)/$(date +%y-%m)/$(date +%y-%m-%d)/Clock.module.css",
    "perf:analyze": "vite build --mode production && npx source-map-explorer 'dist/assets/*.js'",
    "optimize:images": "npx sharp-cli -i ./src/assets/images -o ./src/assets/images --webp"
  },
